# Gmail credentials (use App Password, not your real password)
# https://myaccount.google.com/apppasswords
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password

# Comma-separated recipient emails
NOTIFY_EMAILS=recipient1@example.com,recipient2@example.com

# Optional: Telegram bot notifications
# 1. Create a bot via @BotFather and copy its token
# 2. Get your chat_id: https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
