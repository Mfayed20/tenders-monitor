# Gmail credentials (use App Password, not your real password)
# https://myaccount.google.com/apppasswords
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password

# Comma-separated recipient emails
NOTIFY_EMAILS=recipient1@example.com,recipient2@example.com

# Optional: override default keywords (comma-separated)
# EXTRA_KEYWORDS_EN=solar charging,battery storage
# EXTRA_KEYWORDS_AR=شحن شمسي,تخزين بطارية
