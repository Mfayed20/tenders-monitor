# Telegram bot notifications
# 1. Create a bot via @BotFather and copy its token
# 2. Get your chat_id: https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Runtime configuration
TENDER_OUTPUT_DIR=output
TENDER_SEEN_DB_PATH=output/seen_tenders.db
TENDER_LOG_LEVEL=INFO
TENDER_RUN_WINDOW_HOURS=168
TENDER_CLOSE_WINDOW_DAYS=30
TENDER_DISABLED_SCRAPERS=
TENDER_TELEGRAM_ENABLED=true
TENDER_DRY_RUN=false
